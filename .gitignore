# ==========================================================
# Global Crisis Intelligence Engine
# .gitignore
# ==========================================================

# -----------------------------
# Ignore only raw datasets
# -----------------------------
datasets/raw/

# -----------------------------
# Python
# -----------------------------
__pycache__/
*.py[cod]
*$py.class

# Virtual Environments
venv/
env/
ENV/
.venv/

# Environment Variables
.env
.env.*

# -----------------------------
# IDE
# -----------------------------
.vscode/
.idea/

# -----------------------------
# Jupyter
# -----------------------------
.ipynb_checkpoints/

# -----------------------------
# Logs
# -----------------------------
*.log
logs/

# -----------------------------
# Temporary Files
# -----------------------------
*.tmp
*.temp
.cache/

# -----------------------------
# Build Files
# -----------------------------
build/
dist/
*.egg-info/

# -----------------------------
# Testing
# -----------------------------
.pytest_cache/
.coverage
htmlcov/

# -----------------------------
# Database Backups
# -----------------------------
*.backup
*.bak
*.dump
*.sqlite
*.sqlite3
*.db

# -----------------------------
# Operating System
# -----------------------------
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------
# Archives
# -----------------------------
*.zip
*.rar
*.7z
*.tar
*.gz